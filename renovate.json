{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergeAll"
  ],
  "labels": ["dependencies"],
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,
  "argocd": {
    "fileMatch": ["apps/.+\\.yaml$"]
  },
  "helm-values": {
    "fileMatch": ["charts/.+/values\\.yaml$"]
  },
  "packageRules": [
    {
      "description": "Group Rook-Ceph updates together",
      "matchPackagePatterns": ["rook-ceph"],
      "groupName": "rook-ceph"
    },
    {
      "description": "Group Grafana stack updates",
      "matchPackagePatterns": ["grafana", "loki", "promtail", "tempo"],
      "groupName": "grafana-stack"
    },
    {
      "description": "Major updates — auto-merge but label for visibility",
      "matchUpdateTypes": ["major"],
      "labels": ["major-update"]
    }
  ]
}
