{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergeAll"
  ],
  "labels": ["dependencies"],
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": false,
  "ignoreTests": true,
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,
  "argocd": {
    "fileMatch": ["apps/.+\\.yaml$"]
  },
  "helm-values": {
    "fileMatch": ["charts/.+/values\\.yaml$"]
  },
  "packageRules": [
    {
      "description": "Group Rook-Ceph updates together",
      "matchPackagePatterns": ["rook-ceph"],
      "groupName": "rook-ceph"
    },
    {
      "description": "Group Grafana stack updates",
      "matchPackagePatterns": ["grafana", "loki", "promtail", "tempo"],
      "groupName": "grafana-stack"
    },
    {
      "description": "Major updates — auto-merge but label for visibility",
      "matchUpdateTypes": ["major"],
      "labels": ["major-update"]
    },
    {
      "description": "Hold off major bumps for infra charts with breaking-change risk — require a deliberate PR review",
      "matchPackageNames": [
        "nats",
        "louislam/uptime-kuma",
        "kube-prometheus-stack"
      ],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Gateway API CRDs are hand-curated — see charts/gateway-api-crds/README.md. Bump only when Cilium GA includes cilium#45825.",
      "matchFileNames": [
        "charts/gateway-api-crds/**",
        "apps/platform/gateway-api-crds.yaml"
      ],
      "enabled": false
    }
  ]
}
